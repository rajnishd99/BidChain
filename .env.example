# BidChain environment variables.
# Copy this file to `.env` and fill in the values for your setup.

# --- Stellar network (one of: testnet | futurenet | mainnet) ---
STELLAR_NETWORK=testnet
NEXT_PUBLIC_STELLAR_NETWORK=testnet

# --- Soroban RPC + Horizon URLs (defaults below match the network above) ---
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_STELLAR_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org

# --- Network passphrase (must match the network above) ---
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
NEXT_PUBLIC_STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# --- Server-side deployer identity (used by `make deploy`) ---
# Create one with:  stellar keys generate deployer
# Fund on testnet:  stellar keys fund deployer --network testnet
STELLAR_SOURCE=deployer

# --- Deployed contract id (filled in by `make deploy`) ---
NEXT_PUBLIC_AUCTION_CONTRACT_ID=
NEXT_PUBLIC_CONTRACT_ID=

